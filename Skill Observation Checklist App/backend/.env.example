# =============================================================================
# Skill Observation Checklist App — Environment Variables
# =============================================================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
#
# Generate JWT_SECRET:
#   python -c "import secrets; print(secrets.token_hex(32))"
# =============================================================================

# --- Database (Neon PostgreSQL) ---
# Get this from your Neon dashboard → Connection string
DATABASE_URL=postgresql://<user>:<password>@<host>/neondb?sslmode=require&channel_binding=require

# --- JWT Authentication ---
# REQUIRED. Must be a cryptographically secure random string (min 32 chars).
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace_with_your_secure_random_secret_here

# Kept for legacy compatibility — set to the same value as JWT_SECRET
SECRET_KEY=replace_with_your_secure_random_secret_here

# JWT signing algorithm — do not change unless you know what you're doing
ALGORITHM=HS256

# Token validity in minutes (default: 1440 = 24 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Runtime Environment ---
# Set to "production" on Render / Railway / Vercel
# This disables /docs and /redoc in production
NODE_ENV=development

# --- CORS ---
# Comma-separated list of allowed frontend origins.
# Add your deployed frontend URL for production.
# Example: https://your-app.vercel.app,http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
