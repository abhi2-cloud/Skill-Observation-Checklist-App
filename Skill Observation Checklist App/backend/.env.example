# =============================================================================
# Skill Observation Checklist App — Environment Variables Template
# =============================================================================
# 1. Copy this file:  cp .env.example .env
# 2. Fill in every value marked with  ← REQUIRED
# 3. NEVER commit .env to git (it's in .gitignore)
#
# For Render/Railway/Vercel — add these in the platform dashboard instead.
# =============================================================================


# -----------------------------------------------------------------------------
# DATABASE  ← REQUIRED
# -----------------------------------------------------------------------------
# Get from: Neon Dashboard → Your Project → Connection Details → Connection string
# Format:   postgresql://user:password@host/dbname?sslmode=require&channel_binding=require
DATABASE_URL=postgresql://<user>:<password>@<host>/neondb?sslmode=require&channel_binding=require


# -----------------------------------------------------------------------------
# JWT AUTHENTICATION  ← REQUIRED
# -----------------------------------------------------------------------------
# MUST be a cryptographically secure random string — NOT a placeholder!
#
# Generate your secret (run this command and copy the output):
#   python -c "import secrets; print(secrets.token_hex(32))"
#
# ❌ DO NOT use:  your_secret_key, change_me, secret, replace_me, default_secret
# ✅ USE:        a 64-character random hexadecimal string like the example below
#
JWT_SECRET=<paste-64-char-hex-secret-here>

# Legacy alias — set to the same value as JWT_SECRET
SECRET_KEY=<paste-64-char-hex-secret-here>

# JWT signing algorithm — do not change
ALGORITHM=HS256

# Token validity in minutes  (1440 = 24 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=1440


# -----------------------------------------------------------------------------
# RUNTIME ENVIRONMENT  ← REQUIRED
# -----------------------------------------------------------------------------
# Use "development" locally, "production" on Render/Railway/Vercel
NODE_ENV=development


# -----------------------------------------------------------------------------
# CORS (Cross-Origin Resource Sharing)
# -----------------------------------------------------------------------------
# Comma-separated list of allowed frontend URLs.
# Add your deployed Vercel/Netlify URL for production.
#
# Examples:
#   Local only:       http://localhost:5173,http://127.0.0.1:5173
#   With production:  http://localhost:5173,https://your-app.vercel.app
#
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
